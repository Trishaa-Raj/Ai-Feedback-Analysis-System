        "jsCode": "const agg = $('Aggregate Last 7 Days').first().json;\nconst aiInsight = $input.first().json.output || 'No AI insight generated.';\n\nconst now = new Date();\nconst weekStart = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);\nconst dateRange = `${weekStart.toDateString()} – ${now.toDateString()}`;\n\nconst emailBody = `WEEKLY FEEDBACK REPORT\\n${dateRange}\\n${'='.repeat(40)}\\n\\n📊 TOTAL FEEDBACK RECEIVED: ${agg.totalCount}\\n\\n📂 BREAKDOWN BY CATEGORY:\\n${agg.categoryText}\\n\\n🚨 HIGH PRIORITY COMPLAINTS:\\n${agg.highPriorityText}\\n\\n📈 AVERAGE SENTIMENT SCORE: ${agg.avgSentiment} / 1.0\\n(+1 = very happy, -1 = very frustrated)\\n\\n🤖 AI INSIGHT:\\n${aiInsight}\\n\\n${'='.repeat(40)}\\nAuto-generated by AI Feedback Analysis System v3`;\n\nreturn [{ json: { emailBody, dateRange } }];"
