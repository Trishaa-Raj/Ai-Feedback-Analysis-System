    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output || '';\n\nlet parsed;\ntry {\n  const cleaned = raw.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  parsed = {\n    category: 'Other',\n    sentiment: 0,\n    priority: 'Low',\n    summary: 'Could not parse feedback automatically.'\n  };\n}\n\nconst validCategories = ['Complaint', 'Compliment', 'Query', 'Feature Request', 'Other'];\nif (!validCategories.includes(parsed.category)) {\n  parsed.category = 'Other';\n}\n\n// Build smart reply based on category\nconst name = $('Feedback Form').first().json.Name;\nconst feedback = $('Feedback Form').first().json.Feedback;\n\nconst replyMap = {\n  'Complaint': {\n    subject: `We're on it, ${name} — your complaint has been received`,\n    message: `Hi ${name},\\n\\nWe're sorry to hear about your experience. Your complaint has been flagged as ${parsed.priority} priority and our team will look into it immediately.\\n\\nHere's what you reported:\\n\"${feedback}\"\\n\\nWe take every complaint seriously and will follow up with you if we need more details. Thank you for helping us improve.\\n\\nApologies again,\\nThe Support Team`\n  },\n  'Compliment': {\n    subject: `This made our day, ${name}! 🎉`,\n    message: `Hi ${name},\\n\\nThis made our day! Thank you so much for taking the time to share such kind words.\\n\\nWhat you said:\\n\"${feedback}\"\\n\\nFeedback like yours keeps our team motivated. We truly appreciate you.\\n\\nWith gratitude,\\nThe Team`\n  },\n  'Query': {\n    subject: `We got your question, ${name} — we'll follow up shortly`,\n    message: `Hi ${name},\\n\\nThank you for reaching out! We've received your question and someone from our team will follow up with a detailed answer shortly.\\n\\nYour question:\\n\"${feedback}\"\\n\\nWe aim to respond within 24–48 hours. Stay tuned!\\n\\nBest,\\nThe Support Team`\n  },\n  'Feature Request': {\n    subject: `Love the idea, ${name} — we've logged your feature request`,\n    message: `Hi ${name},\\n\\nThank you for sharing your idea! We've logged your feature request and shared it directly with our product team for review.\\n\\nYour suggestion:\\n\"${feedback}\"\\n\\nWe can't promise a timeline, but every request is considered seriously. We appreciate you helping shape the product.\\n\\nExcited to build,\\nThe Product Team`\n  },\n  'Other': {\n    subject: `Thanks for reaching out, ${name}`,\n    message: `Hi ${name},\\n\\nThank you for getting in touch. We've received your message and our team will review it shortly.\\n\\nYour message:\\n\"${feedback}\"\\n\\nWe'll follow up if needed.\\n\\nBest,\\nThe Team`\n  }\n};\n\nconst reply = replyMap[parsed.category] || replyMap['Other'];\n\nreturn [{\n  json: {\n    ...parsed,\n    Name: name,\n    Email: $('Feedback Form').first().json.Email,\n    Feedback: feedback,\n    replySubject: reply.subject,\n    replyMessage: reply.message\n  }\n}];"
      },
