    {
      "parameters": {
        "jsCode": "const allRows = $input.all();\n\nconst now = new Date();\nconst sevenDaysAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);\n\nconst lastWeekRows = allRows.filter(row => {\n  const rowTime = new Date(row.json.Time);\n  return rowTime >= sevenDaysAgo;\n});\n\nif (lastWeekRows.length === 0) {\n  return [{ json: { hasData: false, totalCount: 0, summaryList: 'No feedback this week.', categoryText: 'None', highPriorityText: 'None', avgSentiment: '0.00', highCount: 0 } }];\n}\n\nconst categoryCounts = {};\nlet sentimentTotal = 0;\nconst summaries = [];\nconst highPriorityComplaints = [];\n\nlastWeekRows.forEach(row => {\n  const cat = row.json.Category || 'Other';\n  categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;\n  sentimentTotal += parseFloat(row.json.Sentiment) || 0;\n  if (row.json.Summary) summaries.push(row.json.Summary);\n  if (row.json.Category === 'Complaint' && row.json.Priority === 'High') {\n    highPriorityComplaints.push(row.json.Summary || row.json.Feedback);\n  }\n});\n\nconst avgSentiment = (sentimentTotal / lastWeekRows.length).toFixed(2);\nconst categoryText = Object.entries(categoryCounts).map(([cat, count]) => `  • ${cat}: ${count}`).join('\\n');\nconst highPriorityText = highPriorityComplaints.length > 0 ? highPriorityComplaints.map(s => `  ⚠️ ${s}`).join('\\n') : '  None this week ✅';\nconst summaryList = summaries.slice(0, 20).join(' | ');\n\nreturn [{ json: { hasData: true, totalCount: lastWeekRows.length, categoryText, highPriorityText, avgSentiment, summaryList, highCount: highPriorityComplaints.length } }];"
      },
